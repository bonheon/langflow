      {
        "id": "PythonFunction-Ij7Kl",
        "type": "genericNode",
        "position": { "x": 950, "y": 300 },
        "data": {
          "id": "PythonFunction-Ij7Kl",
          "type": "PythonFunction",
          "node": {
            "template": {
              "_type": "CustomComponent",
              "llm_output": {
                "type": "str",
                "required": false,
                "placeholder": "",
                "list": false,
                "show": true,
                "multiline": true,
                "value": "",
                "password": false,
                "name": "llm_output",
                "display_name": "llm_output",
                "advanced": false,
                "dynamic": false,
                "info": "",
                "input_types": ["Message"]
              },
              "code": {
                "type": "code",
                "required": true,
                "placeholder": "",
                "list": false,
                "show": true,
                "multiline": true,
                "value": "import json\nimport re\nimport requests\n\ndef call_api(llm_output: str) -> str:\n    \"\"\"\n    LLM 출력(JSON 문자열)을 파싱해서 사내 API를 호출한다.\n    실제 사내 API URL로 교체 필요.\n    \"\"\"\n    # JSON 파싱 (LLM이 ```json 으로 감쌀 수 있으므로 방어 처리)\n    raw = llm_output.strip()\n    match = re.search(r'\\{.*\\}', raw, re.DOTALL)\n    if not match:\n        return json.dumps({\"error\": \"ID를 추출할 수 없습니다\"}, ensure_ascii=False)\n\n    entity = json.loads(match.group())\n    id_type = entity.get(\"type\", \"unknown\")\n    id_value = entity.get(\"id\")\n    intent = entity.get(\"intent\", \"status\")\n\n    if id_type == \"unknown\" or not id_value:\n        return json.dumps({\"error\": \"lot_id 또는 eqp_id를 찾을 수 없습니다\"}, ensure_ascii=False)\n\n    # ── 사내 API 호출 (아래 URL을 실제 API로 교체) ──────────────────\n    # 예시: response = requests.get(\n    #     f\"http://mes-api.internal/{id_type}/{id_value}/{intent}\",\n    #     headers={\"Authorization\": \"Bearer YOUR-MES-KEY\"},\n    #     timeout=10\n    # )\n    # api_data = response.json()\n    # ────────────────────────────────────────────────────────────────\n\n    # Mock 데이터 (API 연동 전 테스트용)\n    mock = {\n        \"lot\": {\n            \"LOT-20240101\": {\n                \"status\":   {\"stage\": \"CVD\", \"equipment\": \"CVD-03\", \"progress\": \"85%\"},\n                \"location\": {\"fab\": \"FAB-2\", \"bay\": \"BAY-3\", \"equipment\": \"CVD-03\"},\n                \"alarm\":    {\"count\": 0, \"last\": None},\n                \"history\":  {\"steps_done\": [\"DIFF\", \"OXIDE\", \"CVD\"], \"current\": \"CVD\"},\n                \"yield\":    {\"target\": \"98%\", \"current\": \"97.2%\"},\n            }\n        },\n        \"eqp\": {\n            \"CVD-03\": {\n                \"status\":   {\"state\": \"RUN\", \"recipe\": \"CVD_OXIDE_V3\", \"wafer_count\": 25},\n                \"alarm\":    {\"count\": 3, \"last\": \"2024-04-01 14:32\", \"code\": \"TEMP_HIGH\"},\n                \"history\":  {\"last_pm\": \"2024-03-15\", \"total_run\": 1423},\n                \"location\": {\"fab\": \"FAB-2\", \"bay\": \"BAY-3\", \"chamber\": \"CH-A\"},\n                \"yield\":    {\"avg_yield\": \"96.8%\", \"period\": \"최근 30일\"},\n            }\n        },\n    }\n\n    api_data = mock.get(id_type, {}).get(id_value, {}).get(intent, {\"message\": \"데이터 없음\"})\n\n    result = {\n        \"type\": id_type,\n        \"id\": id_value,\n        \"intent\": intent,\n        \"data\": api_data,\n    }\n    return json.dumps(result, ensure_ascii=False, indent=2)\n",
                "password": false,
                "name": "code",
                "display_name": "API Caller (사내 API 연동 코드)",
                "advanced": false,
                "dynamic": false,
                "info": ""
              }
            },
            "display_name": "API Caller",
            "description": "LLM 추출 결과를 기반으로 사내 API 호출",
            "base_classes": ["Message"],
            "output_types": ["Message"],
            "documentation": "",
            "custom_fields": {}
          }
        }
